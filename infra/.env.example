# ──────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your secrets before deploying.
# NEVER commit the real .env file to source control.
# ──────────────────────────────────────────────────────────────────────────────

# API key for the REST API service (X-Api-Key header)
API_KEY=change-me-in-production

# API key for the WebSocket service (?apiKey= query param or X-Api-Key header)
WS_API_KEY=change-me-in-production

# Full EF Core connection string injected into the api container
ConnectionStrings__DefaultConnection=Host=postgres;Port=5432;Database=appdb;Username=appuser;Password=change-me

# PostgreSQL container credentials (must match the connection string above)
POSTGRES_USER=appuser
POSTGRES_PASSWORD=change-me
POSTGRES_DB=appdb
